{
  "name": "http-client-csharp",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@alloy-js/core": "0.22.0",
    "@alloy-js/csharp": "0.22.0",
    "@alloy-js/msbuild": "0.22.0",
    "@alloy-js/typescript": "0.22.0",
    "@typespec/emitter-framework": "^0.16.0"
  },
  "main": "dist/src/index.js",
  "peerDependencies": {
    "@azure-tools/typespec-client-generator-core": ">=0.65.3 <0.66.0 || ~0.66.0-0",
    "@typespec/compiler": "^1.9.0",
    "@typespec/http": "^1.9.0",
    "@typespec/rest": ">=0.79.0 <0.80.0 || ~0.80.0-0"
  },
  "devDependencies": {
    "@alloy-js/cli": "0.22.0",
    "@alloy-js/rollup-plugin": "0.1.0",
    "@azure-tools/typespec-client-generator-core": ">=0.65.3 <0.66.0",
    "@eslint/js": "^9.39.3",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@typespec/compiler": "1.9.0",
    "@typespec/http": "^1.9.0",
    "@typespec/rest": ">=0.79.0 <0.80.0",
    "@typespec/versioning": ">=0.79.0 <0.80.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tree-sitter-c-sharp": "^0.23.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4",
    "web-tree-sitter": "^0.26.6"
  },
  "scripts": {
    "build": "alloy build",
    "clean": "rimraf dist/ .temp/",
    "test": "vitest run",
    "test:watch": "vitest -w",
    "watch": "alloy build --watch",
    "lint": "eslint src/ test/ --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint . --report-unused-disable-directives --fix",
    "format": "prettier .  --write",
    "format:check": "prettier --check .",
    "ralph": "node scripts/ralph.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./stc": {
      "import": "./dist/src/stc.js",
      "types": "./dist/src/stc.d.ts"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "default": "./dist/src/testing/index.js"
    }
  }
}
